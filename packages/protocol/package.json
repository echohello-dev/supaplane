{
  "name": "@echohello/protocol",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./connection-offer": "./dist/connection-offer.js",
    "./messages": "./dist/messages.js",
    "./provider-manifest": "./dist/provider-manifest.js",
    "./errors": "./dist/errors.js",
    "./daemon-endpoints": "./dist/daemon-endpoints.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:clean": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsgo -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src --config ../../oxlint.jsonc"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
