{
  "name": "@echohello/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:clean": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsgo -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src --config ../../oxlint.jsonc"
  },
  "dependencies": {
    "@echohello/protocol": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
