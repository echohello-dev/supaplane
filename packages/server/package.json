{
  "name": "@echohello/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./exports": "./src/server/exports.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./exports": {
        "types": "./dist/server/exports.d.ts",
        "default": "./dist/server/exports.js"
      }
    },
    "main": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:clean": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsgo -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src --config ../../oxlint.jsonc"
  },
  "dependencies": {
    "@echohello/client": "workspace:*",
    "@echohello/protocol": "workspace:*",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "pino": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "rotating-file-stream": "^3.2.9",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.14",
    "vitest": "^2.1.0"
  }
}
